# Copy to .env.local (dev) or set in Railway / hosting dashboard (production).

# --- PostgreSQL / Prisma (prisma.config.ts → DATABASE_URL) ---
# Railway internal host `postgres.railway.internal` works only inside Railway’s network.
# On your PC, `npx prisma db push` / `migrate` need the **public** connection string:
#   Railway → Postgres service → Connect → “Public network” / external URL.
# Use that URL in .env.local for local CLI; on Railway keep the internal URL for the app.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.region.railway.app:PORT/railway?sslmode=require

# --- Auth.js / NextAuth ---
# Public origin only (no trailing slash). Callback URLs are NOT separate env vars — they are always:
#   {AUTH_URL}/api/auth/callback/google
#   {AUTH_URL}/api/auth/callback/discord
#   {AUTH_URL}/api/auth/callback/facebook
# Register those exact URLs in Google Cloud Console + Discord Developer Portal (must match AUTH_URL host).
# Local dev example: AUTH_URL=http://localhost:3000  →  http://localhost:3000/api/auth/callback/google
NEXTAUTH_URL=
AUTH_URL=
# JWT signing — use ONE of these (same value). Generate: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_SECRET=

# Google OAuth — Client ID + Secret from Google Cloud Console → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth — Application → OAuth2 (never commit real secrets)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Public URL (Stripe success/cancel, metadata, sitemap) ---
NEXT_PUBLIC_APP_URL=https://www.neonchat.live
NEXT_PUBLIC_SITE_URL=https://www.neonchat.live

# --- Stripe (production) ---
# Secret: Dashboard → API keys (`sk_live_...`). Alias: STRIPE_API_KEY
STRIPE_SECRET_KEY=
# Publishable: `pk_live_...` — either name works (see lib/stripe.ts)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Checkout return URLs (optional — defaults: profile success, billing cancel)
# STRIPE_CHECKOUT_SUCCESS_PATH=/profile?payment=success
# STRIPE_CHECKOUT_CANCEL_PATH=/billing?canceled=1
# Or full URLs: STRIPE_CHECKOUT_SUCCESS_URL=https://www.neonchat.live/profile?payment=success
# Stripe Tax in Dashboard must be configured. Set to false if Tax isn’t enabled (e.g. some dev sandboxes).
# STRIPE_AUTOMATIC_TAX=false
