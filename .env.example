# Copy to .env.local (dev) or set in Railway / hosting dashboard (production).

# --- PostgreSQL / Prisma (prisma.config.ts → DATABASE_URL) ---
# Railway internal host `postgres.railway.internal` works only inside Railway’s network.
# On your PC, `npx prisma db push` / `migrate` need the **public** connection string:
#   Railway → Postgres service → Connect → “Public network” / external URL.
# Use that URL in .env.local for local CLI; on Railway keep the internal URL for the app.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.region.railway.app:PORT/railway?sslmode=require

# --- Auth.js / NextAuth ---
# Public origin only (no trailing slash). Callback URLs are NOT separate env vars — they are always:
#   {AUTH_URL}/api/auth/callback/google
#   {AUTH_URL}/api/auth/callback/discord
#   {AUTH_URL}/api/auth/callback/facebook
# Register those exact URLs in Google Cloud Console + Discord Developer Portal (must match AUTH_URL host).
# Local dev example: AUTH_URL=http://localhost:3000  →  http://localhost:3000/api/auth/callback/google
NEXTAUTH_URL=
AUTH_URL=
# JWT signing — use ONE of these (same value). Generate: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_SECRET=

# Google OAuth — Client ID + Secret from Google Cloud Console → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth — Application → OAuth2 (never commit real secrets)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Magic link email (Resend) ---
# Resend → API Keys (either name works):
# RESEND_API_KEY=
# AUTH_RESEND_KEY=
# From: optional — code defaults to NeonLive <login@neonlive.chat> (verified domain).
# Override if needed, e.g. dev with Resend onboarding address:
# EMAIL_FROM="NeonLive <login@neonlive.chat>"
# AUTH_EMAIL_FROM=  (alias for EMAIL_FROM)

# --- Public URL (Stripe success/cancel, metadata, sitemap) ---
NEXT_PUBLIC_APP_URL=https://www.neonchat.live
NEXT_PUBLIC_SITE_URL=https://www.neonchat.live
# Referral share links use NEXT_PUBLIC_APP_URL when set (e.g. https://www.neonlive.chat).

# --- Referrals (optional) ---
# POST /api/referral/reward — Bearer token for server-to-server calls (webhook can use lib directly instead).
# REFERRAL_REWARD_SECRET=

# --- Stripe (production) ---
# Secret: Dashboard → API keys (`sk_live_...` / `sk_test_...`) — must be named STRIPE_SECRET_KEY on Railway
STRIPE_SECRET_KEY=
# Publishable: `pk_live_...` — either name works (see lib/stripe.ts)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Checkout return URLs (optional — defaults: profile success, billing cancel)
# STRIPE_CHECKOUT_SUCCESS_PATH=/profile?payment=success
# STRIPE_CHECKOUT_CANCEL_PATH=/billing?canceled=1
# Or full URLs: STRIPE_CHECKOUT_SUCCESS_URL=https://www.neonchat.live/profile?payment=success
# Stripe Tax in Dashboard must be configured. Set to false if Tax isn’t enabled (e.g. some dev sandboxes).
# STRIPE_AUTOMATIC_TAX=false

# --- Anthropic (AI moderation: global chat, nicknames, report triage) ---
# Dashboard: https://console.anthropic.com/ — add to Railway env for production.
ANTHROPIC_API_KEY=
# Optional override (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODERATION_MODEL=

# --- Supabase (avatar upload: POST /api/profile/avatar) ---
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# Client Realtime / browser helpers (supabase-browser.ts):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Create a public Storage bucket named `avatars` (or uploads will return 502 from the avatar route).

# --- Facebook OAuth (optional — same callback pattern as Google) ---
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# Aliases also supported: AUTH_FACEBOOK_ID, AUTH_FACEBOOK_SECRET

# --- Video (Agora) ---
# NEXT_PUBLIC_AGORA_APP_ID=
# AGORA_APP_CERTIFICATE=

# --- OpenAI (Neon Whisper API, content-sentinel paths) ---
# OPENAI_API_KEY=

# --- Sightengine (image moderation API) ---
# SIGHTENGINE_API_USER=
# SIGHTENGINE_API_SECRET=

# --- Lemon Squeezy (legacy/alternate checkout + webhooks) ---
# LEMON_SQUEEZY_API_KEY=
# LEMON_SQUEEZY_STORE_ID=
# LEMON_SQUEEZY_WEBHOOK_SECRET=
# NEXT_PUBLIC_LEMON_VARIANT_STARTER=
# NEXT_PUBLIC_LEMON_VARIANT_NEON=
# NEXT_PUBLIC_LEMON_VARIANT_HYPER=
# NEXT_PUBLIC_LEMON_VARIANT_GHOST=

# --- Custom Node server (server.js) / Socket.IO ---
# Railway sets PORT automatically — do not override unless you know why.
# PORT=
# HOSTNAME=0.0.0.0
# Extra allowed origins for Socket.IO (comma-separated):
# SOCKET_IO_EXTRA_ORIGINS=https://www.example.com

# --- Secured cron routes (/api/cron/*) ---
# CRON_SECRET=

# --- Admin / moderation dashboards ---
# ADMIN_EMAIL=you@example.com
# ADMIN_USER_ID=
# ADMIN_EMAILS=comma,separated@emails

# --- Ads (optional) ---
# NEXT_PUBLIC_ADSENSE_CLIENT=
# NEXT_PUBLIC_ADSENSE_SLOT=

# --- Stripe server-only publishable alias (optional; browser still needs NEXT_PUBLIC_* ) ---
# STRIPE_PUBLIC_KEY=
