datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

/// NextAuth / Auth.js `User` — extended with app fields. OAuth links via `Account`.
model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  coins            Int       @default(0)
  isGhost          Boolean   @default(false)
  country          String?
  referralCount    Int       @default(0)
  totalCoinsSpent  Int       @default(0)
  /// Lifetime USD spent on Stripe billing packs / checkouts (for VIP glow, analytics)
  totalSpent       Float     @default(0)
  hasEverPurchased Boolean   @default(false)
  tier             String    @default("NEON_FREE")
  lastLogin        DateTime  @default(now())
  /// Consecutive UTC calendar days with a qualifying login
  currentStreak    Int       @default(0)
  /// Set to coin amount (e.g. 10) when streak bonus granted; cleared on next GET /api/profile/me
  streakBonusPopup Int       @default(0)
  /// Whale pack ($18.99) & high-tier visual perks
  isVip            Boolean   @default(false)
  /// Optional custom animated banner URL (GIF/Lottie hosted URL)
  animatedBanner   String?
  /// Profile avatar GIF URL (Neon VIP / whale pack only)
  profileGifUrl    String?
  /// Level 5+ cosmetic: matrix | waves | stars | null (default gradient)
  profileBannerEffect String?
  xp               Int       @default(0)
  currentLevel     Int       @default(1)
  /// Best score across future in-app arcade / mini-games
  highScore        Int       @default(0)
  /// Currency for future arcade modes (earn / spend in-game)
  arcadeTokens     Int       @default(0)
  ghostModeUntil   DateTime? // Status boost: Ghost Mode until this timestamp
  isShadowBanned   Boolean   @default(false)
  moderationFlags  String?   // JSON: { toxicCount, nsfwCount, lastFlaggedAt }
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  accounts         Account[]
  sessions         Session[]
  sentTransactions Transaction[]   @relation("TransactionSender")
  receivedTransactions Transaction[] @relation("TransactionReceiver")
  inventory        UserInventory[]
  notifications    Notification[]
  activityLogs     ActivityLog[]
  reportsGiven     Report[]  @relation("ReportReporter")
  reportsReceived  Report[]  @relation("ReportReported")
  stripePurchases         StripePurchase[]
  walletCreditTransactions WalletCreditTransaction[]
  /// Optional cover image URL (LinkedIn-style); empty = default gradient
  profileBannerUrl String?
  /// Short public bio, max 150 chars (enforced in API)
  bio              String?
  /// Profile display: male | female | other (optional)
  profileGender    String?
  /// JSON string: ISO language codes user speaks, e.g. ["en","ro"]
  profileLanguages String?
  socialInstagram  String?
  socialTiktok     String?
  socialDiscord    String?
  /// Updated on Socket register/disconnect for “last seen”
  lastSeenAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  profileGalleryImages   ProfileGalleryImage[]
  friendshipsRequested   Friendship[]          @relation("FriendshipRequester")
  friendshipsReceived    Friendship[]          @relation("FriendshipAddressee")
  privateMessagesSent    PrivateMessage[]      @relation("DmSender")
  privateMessagesReceived PrivateMessage[]     @relation("DmReceiver")

  @@index([xp])
  @@index([currentLevel])
  @@index([isShadowBanned])
}

model Level {
  id         String @id @default(cuid())
  level      Int    @unique
  xpRequired Int
  badgeIcon  String
}

model UserInventory {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  itemType  String   // 'reaction_gift' | 'elite_gift' | 'status_boost'
  quantity  Int      @default(1)
  expiresAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // 'GIFT' | 'FOLLOW' | 'LEVEL_UP' | 'achievement'
  title     String
  message   String?
  body      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Report {
  id             String   @id @default(cuid())
  reporterId     String
  reportedUserId String
  reason         String?
  status         String   @default("pending") // pending | reviewed | dismissed | action_taken
  adminNotes     String?
  createdAt      DateTime @default(now())
  reviewedAt     DateTime?

  reporter   User @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported   User @relation("ReportReported", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([status])
  @@index([createdAt])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  activityType String // 'login' | 'gift_sent' | 'gift_received'
  xpEarned   Int      @default(0)
  metadata   String?  // JSON: { coins, giftType, etc }
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

/// NextAuth `Session` — used when session strategy is `database`; kept for adapter compatibility.
model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// NextAuth `VerificationToken` — email magic links.
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Streak {
  id                   String    @id @default(cuid())
  userId               String    @unique
  streakCount          Int       @default(0)
  lastLoginDate        DateTime?
  loyalBadgeUnlockedAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
}

model Transaction {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  amount     Int
  type       String   // 'GIFT' | 'PURCHASE' | 'STRIPE_PURCHASE'
  giftType   String?
  itemId     String?  // For shop purchases
  promocodeId String? // If used a creator promocode
  /** Stripe Checkout: 'completed' when coins credited; null for legacy gift rows */
  status          String?
  /** Idempotency — one ledger row per Checkout session */
  stripeSessionId String? @unique
  createdAt  DateTime @default(now())

  sender   User @relation("TransactionSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("TransactionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  promocode Promocode? @relation(fields: [promocodeId], references: [id], onDelete: SetNull)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([promocodeId])
}

/**
 * Stripe (and future) wallet credits — one row per successful checkout credit.
 * Distinct from peer-to-peer `Transaction` (gifts).
 */
model WalletCreditTransaction {
  id              String   @id @default(cuid())
  userId          String
  amount          Int
  status          String
  provider        String   @default("stripe")
  stripeSessionId String?  @unique
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("wallet_credit_transactions")
}

/** Stripe Checkout purchases (coins / platform credits) — separate from peer-to-peer Transaction gifts */
model StripePurchase {
  id              String   @id @default(cuid())
  userId          String
  amountUsd       Float
  currency        String   @default("USD")
  status          String   // pending | completed | failed
  stripeSessionId String   @unique
  coinsAdded      Int      @default(0)
  packId          String?  // small | medium | whale | null for legacy plan checkouts
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Promocode {
  id         String   @id @default(cuid())
  creatorId  String
  code       String   @unique
  bonusPercent Int    @default(10)
  usedCount  Int      @default(0)
  createdAt  DateTime @default(now())

  transactions Transaction[]

  @@index([creatorId])
}

model CreatorPayout {
  id        String   @id @default(cuid())
  userId    String
  amountEur Decimal  @db.Decimal(10, 2)
  status    String   // 'pending' | 'completed' | 'failed'
  paidAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model CreatorGoal {
  id          String   @id @default(cuid())
  userId      String   @unique
  title       String
  targetCoins Int
  currentCoins Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

/// Global Pulse world chat — short-lived rows (TTL enforced in app + optional SQL helper).
model ChatMessage {
  id          String   @id @default(cuid())
  userId      String
  userName    String
  countryCode String?  @db.VarChar(2)
  message     String   @db.VarChar(280)
  /// Snapshot: sender had Neon VIP (whale) at post time — for gold/blue name glow in history
  neonVip     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

/// Character / persona gallery — exactly 3 slots (0–2) per user.
model ProfileGalleryImage {
  id        String   @id @default(cuid())
  userId    String
  slot      Int
  imageUrl  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slot])
  @@index([userId])
  @@map("profile_gallery_images")
}

/// Friend requests & accepted friendships (requester → addressee).
model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  addresseeId String
  status      String   @default("pending") // pending | accepted | declined
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@index([status])
  @@map("friendships")
}

/// Direct messages between friends (not Global Pulse).
model PrivateMessage {
  id          String    @id @default(cuid())
  senderId    String
  receiverId  String
  body        String    @db.VarChar(2000)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  sender   User @relation("DmSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("DmReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, createdAt])
  @@map("private_messages")
}
