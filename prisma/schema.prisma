datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

/// NextAuth / Auth.js `User` — extended with app fields. OAuth links via `Account`.
model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  /// Public display name in video chat; 3–20 chars, [a-zA-Z0-9_], unique when set
  nickname         String?   @unique
  coins            Int       @default(0)
  isGhost          Boolean   @default(false)
  country          String?
  /// Unique share code for ?ref= (uuid); backfilled lazily if null (existing users)
  referralCode     String?   @unique
  /// Set when user registered via someone else's referral link
  referredBy       String?
  referralCount    Int       @default(0)
  /// Lifetime coins earned as a referrer (signup bonuses)
  referralCoins    Int       @default(0)
  totalCoinsSpent  Int       @default(0)
  tier             String    @default("NEON_FREE")
  lastLogin        DateTime  @default(now())
  /// Consecutive UTC calendar days with a qualifying daily-login claim
  currentStreak    Int       @default(0)
  /// Best streak length achieved
  longestStreak    Int       @default(0)
  /// Last UTC day daily streak reward was claimed (POST /api/user/daily-login)
  lastLoginDate    DateTime?
  /// Running total of coins granted from daily login streak rewards
  totalCoinsEarned Int       @default(0)
  /// Set to coin amount (e.g. 10) when streak bonus granted; cleared on next GET /api/profile/me
  streakBonusPopup Int       @default(0)
  /// Whale pack ($18.99) & high-tier visual perks
  isVip            Boolean   @default(false)
  /// Cosmetic + matchmaking tier: free | bronze | silver | gold (synced from totalSpent + isVip)
  vipTier          String    @default("free") @db.VarChar(16)
  /// Optional custom animated banner URL (GIF/Lottie hosted URL)
  animatedBanner   String?
  /// Profile avatar GIF URL (Neon VIP / whale pack only)
  profileGifUrl    String?
  /// Level 5+ cosmetic: matrix | waves | stars | null (default gradient)
  profileBannerEffect String?
  xp               Int       @default(0)
  currentLevel     Int       @default(1)
  /// Best score across future in-app arcade / mini-games
  highScore        Int       @default(0)
  /// Currency for future arcade modes (earn / spend in-game)
  arcadeTokens     Int       @default(0)
  ghostModeUntil   DateTime? // Status boost: Ghost Mode until this timestamp
  isShadowBanned   Boolean   @default(false)
  /// Auto: 3 reports in 10 min → 1h matching suspension (cleared after expiry; admin may use isShadowBanned)
  systemSuspensionUntil DateTime?
  /// AI / auto-mod: temporary account ban (e.g. 24h); checked with tier BANNED on sockets & APIs
  bannedUntil      DateTime?
  /// Count of medium-severity AI blocks (global chat)
  warnings         Int       @default(0)
  /// Set when AI moderation flags or auto-actions the account
  autoFlagged      Boolean   @default(false)
  moderationFlags  String?   // JSON: { toxicCount, nsfwCount, lastFlaggedAt }
  accounts         Account[]
  sessions         Session[]
  authenticators   Authenticator[]
  sentTransactions Transaction[]   @relation("TransactionSender")
  receivedTransactions Transaction[] @relation("TransactionReceiver")
  inventory        UserInventory[]
  notifications    Notification[]
  activityLogs     ActivityLog[]
  reportsGiven     Report[]  @relation("ReportReporter")
  reportsReceived  Report[]  @relation("ReportReported")
  /// Optional cover image URL (LinkedIn-style); empty = default gradient
  profileBannerUrl String?
  /// Custom avatar (Supabase Storage); falls back to `image` (OAuth) when null
  avatarUrl        String?
  /// Short public bio, max 150 chars (enforced in API)
  bio              String?
  /// Profile display: male | female | other (optional)
  profileGender    String?
  /// JSON string: ISO language codes user speaks, e.g. ["en","ro"]
  profileLanguages String?
  socialInstagram  String?
  socialTiktok     String?
  /// X / Twitter profile URL
  socialTwitter    String?
  socialDiscord    String?
  /// Lifetime completed random matches (incremented when a pair is formed)
  totalMatches     Int       @default(0)
  /// Approx. minutes on-site (throttled heartbeat from client)
  totalOnlineMinutes Int     @default(0)
  /// Last throttled heartbeat — used to count ~1 online minute per interval
  profileHeartbeatAt DateTime?
  /// Updated on Socket register/disconnect for “last seen”
  lastSeenAt       DateTime  @default(now())
  /// AI Whisper: minutes consumed today (UTC calendar day); reset in API at midnight UTC
  translationMinutesToday Int       @default(0)
  /// Last time translation usage was reset or counted — used with UTC day boundary
  translationResetAt      DateTime  @default(now())
  /// One-time 50-coin welcome after nickname setup (POST /api/user/welcome-bonus)
  welcomeBonusGranted     Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  referrer         User?     @relation("UserReferralInviter", fields: [referredBy], references: [id], onDelete: SetNull)
  usersReferred    User[]    @relation("UserReferralInviter")
  referralsMade    Referral[] @relation("ReferralReferrer")
  referralAsInvitee Referral? @relation("ReferralInvitee")

  profileGalleryImages   ProfileGalleryImage[]
  friendshipsRequested   Friendship[]          @relation("FriendshipRequester")
  friendshipsReceived    Friendship[]          @relation("FriendshipAddressee")
  privateMessagesSent    PrivateMessage[]      @relation("DmSender")
  privateMessagesReceived PrivateMessage[]     @relation("DmReceiver")
  blocksOutgoing         UserBlock[]           @relation("UserBlockBlocker")
  blocksIncoming         UserBlock[]           @relation("UserBlockBlocked")
  badges                 Badge[]
  moderationLogs         ModerationLog[]

  @@index([xp])
  @@index([currentLevel])
  @@index([isShadowBanned])
}

/// One row per invited user; tracks signup referral rewards
model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String   @unique
  coinsAwarded Int
  createdAt    DateTime @default(now())

  referrer User @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("ReferralInvitee", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([createdAt])
}

model Level {
  id         String @id @default(cuid())
  level      Int    @unique
  xpRequired Int
  badgeIcon  String
}

model UserInventory {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  itemType  String   // 'reaction_gift' | 'elite_gift' | 'status_boost'
  quantity  Int      @default(1)
  expiresAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  /// gift | match | streak | referral | system | vip (+ legacy uppercase e.g. GIFT)
  type      String   @db.VarChar(32)
  title     String
  message   String   @default("")
  read      Boolean  @default(false)
  /// In-app path e.g. /profile, /billing — optional deep link when row is clicked
  link      String?  @db.VarChar(512)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Report {
  id             String   @id @default(cuid())
  reporterId     String
  reportedUserId String
  reason         String?
  /// Free-text context from the reporter (profile / in-app report UI)
  details        String?
  status         String   @default("pending") // pending | reviewed | dismissed | action_taken
  adminNotes     String?
  resolved       Boolean  @default(false)
  /// AI triage: low | medium | urgent
  aiPriority     String?
  createdAt      DateTime @default(now())
  reviewedAt     DateTime?

  reporter   User @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported   User @relation("ReportReported", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([status])
  @@index([createdAt])
}

/// AI moderation audit trail (global chat, nickname attempts, etc.)
model ModerationLog {
  id        String   @id @default(cuid())
  userId    String
  content   String   @db.Text
  reason    String
  severity  String
  action    String // blocked | warned | banned
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([severity])
  @@index([action])
  @@index([createdAt])
}

/// User A blocks B → neither is matched with the other in the pool
model UserBlock {
  id         String   @id @default(cuid())
  blockerId  String
  blockedId  String
  createdAt  DateTime @default(now())

  blocker User @relation("UserBlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  activityType String // 'login' | 'gift_sent' | 'gift_received'
  xpEarned   Int      @default(0)
  metadata   String?  // JSON: { coins, giftType, etc }
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

/// NextAuth `Session` — used when session strategy is `database`; kept for adapter compatibility.
model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// NextAuth `VerificationToken` — email magic links.
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

/// WebAuthn / Passkeys — `PrismaAdapter` exposes CRUD for this model (see `@auth/prisma-adapter`).
model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model Streak {
  id                   String    @id @default(cuid())
  userId               String    @unique
  streakCount          Int       @default(0)
  lastLoginDate        DateTime?
  loyalBadgeUnlockedAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
}

model Transaction {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  amount     Int
  type       String   // 'GIFT' | 'PURCHASE'
  giftType   String?
  itemId     String?  // For shop purchases
  createdAt  DateTime @default(now())

  sender   User @relation("TransactionSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("TransactionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

/// Global Pulse world chat — short-lived rows (TTL enforced in app + optional SQL helper).
model ChatMessage {
  id          String   @id @default(cuid())
  userId      String
  userName    String
  countryCode String?  @db.VarChar(2)
  message     String   @db.VarChar(280)
  /// text | reaction — one-tap emoji posts in the same feed
  kind        String   @default("text") @db.VarChar(16)
  /// Snapshot: sender had Neon VIP (whale) at post time — for gold/blue name glow in history
  neonVip     Boolean  @default(false)
  /// Snapshot: sender VIP tier at post time (world vs gold lounge styling + history)
  vipTier     String   @default("free") @db.VarChar(16)
  /// world | gold — gold lounge messages only go to Gold-tier room
  pulseChannel String  @default("world") @db.VarChar(16)
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

/// Character / persona gallery — exactly 3 slots (0–2) per user.
model ProfileGalleryImage {
  id        String   @id @default(cuid())
  userId    String
  slot      Int
  imageUrl  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slot])
  @@index([userId])
  @@map("profile_gallery_images")
}

/// Friend requests & accepted friendships (requester → addressee).
model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  addresseeId String
  status      String   @default("pending") // pending | accepted | declined
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@index([status])
  @@map("friendships")
}

/// Direct messages between friends (not Global Pulse).
model PrivateMessage {
  id          String    @id @default(cuid())
  senderId    String
  receiverId  String
  body        String    @db.VarChar(2000)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  sender   User @relation("DmSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("DmReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, createdAt])
  @@map("private_messages")
}

/// Email OTP for passwordless login (code column stores scrypt hash: "saltHex:keyHex").
model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
  @@map("otp_codes")
}

/// Auto-awarded profile badges (first_match, 100_matches, top_gifter, vip, veteran)
model Badge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  createdAt DateTime @default(now())

  @@unique([userId, type])
  @@index([userId])
  @@map("badges")
}
